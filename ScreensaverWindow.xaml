<Window x:Class="AerialWindows.ScreensaverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AerialWindows"
        mc:Ignorable="d"
        Title="Aerial Screensaver" Height="1080" Width="1920"
        WindowStyle="None" ResizeMode="NoResize" Topmost="True"
        Background="Black" Cursor="None" Icon="/logo.png"
        Loaded="Window_Loaded" 
        KeyDown="Window_KeyDown"
        MouseDown="Window_MouseDown"
        MouseMove="Window_MouseMove">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Dropshadow effect for overlay text readability -->
        <DropShadowEffect x:Key="TextShadow" BlurRadius="6" ShadowDepth="2" Direction="315" Color="Black" Opacity="0.9"/>
        
        <!-- Base Text Style -->
        <Style x:Key="OverlayText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Effect" Value="{StaticResource TextShadow}"/>
            <Setter Property="FontFamily" Value="Segoe UI, Inter, Arial"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="-4">
        <!-- The background video player -->
        <MediaElement x:Name="Player" Stretch="UniformToFill" 
                      LoadedBehavior="Manual" UnloadedBehavior="Close" Volume="0.0"
                      MediaEnded="Player_MediaEnded" MediaOpened="Player_MediaOpened"
                      MediaFailed="Player_MediaFailed"
                      RenderTransformOrigin="0.5,0.5">
            <MediaElement.RenderTransform>
                <ScaleTransform x:Name="PlayerScale" ScaleX="1.0" ScaleY="1.0"/>
            </MediaElement.RenderTransform>
        </MediaElement>

        <!-- Overlays Layer -->
        <Grid x:Name="OverlaysGrid">
            <!-- 3x3 Layout Grid for exact overlay positioning -->
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Anchor Containers for Positional Panels -->
            <!-- Row 0: Top Row -->
            <StackPanel x:Name="PanelTopLeft" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="50,40" Orientation="Vertical"/>
            <StackPanel x:Name="PanelTopRight" Grid.Row="0" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="50,40" Orientation="Vertical"/>

            <!-- Row 1: Middle Row (Center) -->
            <StackPanel x:Name="PanelCenter" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="50" Orientation="Vertical"/>

            <!-- Row 2: Bottom Row -->
            <StackPanel x:Name="PanelBottomLeft" Grid.Row="2" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="50,45" Orientation="Vertical"/>
            <StackPanel x:Name="PanelBottomRight" Grid.Row="2" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="50,45" Orientation="Vertical"/>
        </Grid>
    </Grid>
</Window>
